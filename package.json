{
  "name": "business-ai-assistant",
  "version": "1.0.0",
  "description": "Business AI Assistant with integrated APIs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc",
    "build:client": "cd client && npm run build",
    "test": "jest",
    "docker:build": "docker build -t business-ai-assistant .",
    "docker:run": "docker run -p 3000:3000 business-ai-assistant"
  },
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.0.3",
    "stripe": "^12.0.0",
    "shopify-api": "^8.0.0",
    "mailchimp": "^1.3.4",
    "googleapis": "^118.0.0",
    "axios": "^1.4.0",
    "cheerio": "^1.0.0-rc.12",
    "pg": "^8.10.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "express-validator": "^7.0.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "typescript": "^5.1.3",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.2"
  }
}
